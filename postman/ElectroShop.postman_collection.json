{
  "info": {
    "name": "ElectroShop API",
    "description": "Full REST API for the ElectroShop e-commerce backend (Spring Boot). Base URL and JWT tokens are managed via collection variables. Run 'Auth / Login (admin)' first to populate {{accessToken}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "productId", "value": "1" },
    { "key": "orderId", "value": "1" },
    { "key": "userId", "value": "2" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"New Customer\",\n  \"email\": \"new.customer@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@electroshop.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Login (user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@electroshop.com\",\n  \"password\": \"user123\"\n}"
            }
          }
        },
        {
          "name": "Refresh token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List products",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/products?page=0&size=12&search=&category="
          }
        },
        {
          "name": "Get product by id",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "Get categories",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/products/categories"
          }
        },
        {
          "name": "Create product (ADMIN)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Xiaomi 14\",\n  \"description\": \"Snapdragon 8 Gen 3, Leica camera.\",\n  \"price\": 3999.00,\n  \"stockQuantity\": 20,\n  \"category\": \"Smartphones\",\n  \"brand\": \"Xiaomi\",\n  \"imageUrl\": \"https://example.com/xiaomi14.jpg\"\n}"
            }
          }
        },
        {
          "name": "Update product (ADMIN)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/products/{{productId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"iPhone 15 Pro (updated)\",\n  \"description\": \"Updated description\",\n  \"price\": 5299.00,\n  \"stockQuantity\": 30,\n  \"category\": \"Smartphones\",\n  \"brand\": \"Apple\"\n}"
            }
          }
        },
        {
          "name": "Upload product image (ADMIN)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/products/{{productId}}/image",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": [] }]
            }
          }
        },
        {
          "name": "Delete product (ADMIN)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        }
      ]
    },
    {
      "name": "Orders (user)",
      "item": [
        {
          "name": "Place order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) pm.collectionVariables.set('orderId', res.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": \"Str. Exemplu 1, Bucuresti\",\n  \"items\": [\n    { \"productId\": 1, \"quantity\": 1 },\n    { \"productId\": 5, \"quantity\": 2 }\n  ]\n}"
            }
          }
        },
        {
          "name": "My orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders?page=0&size=10"
          }
        },
        {
          "name": "My order by id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Current profile (me)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/me"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard stats",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/dashboard" }
        },
        {
          "name": "List users",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/users?page=0&size=10&search=" }
        },
        {
          "name": "Create user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/admin/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Manager\",\n  \"email\": \"manager@electroshop.com\",\n  \"password\": \"manager123\",\n  \"enabled\": true,\n  \"roles\": [\"ROLE_ADMIN\", \"ROLE_USER\"]\n}"
            }
          }
        },
        {
          "name": "Update user",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/admin/users/{{userId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Demo User Updated\",\n  \"email\": \"user@electroshop.com\",\n  \"enabled\": true,\n  \"roles\": [\"ROLE_USER\"]\n}"
            }
          }
        },
        {
          "name": "Delete user",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/admin/users/{{userId}}" }
        },
        {
          "name": "List orders",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/orders?page=0&size=10&status=" }
        },
        {
          "name": "Update order status",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/admin/orders/{{orderId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"SHIPPED\"\n}"
            }
          }
        },
        {
          "name": "Delete order",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/admin/orders/{{orderId}}" }
        }
      ]
    }
  ]
}
